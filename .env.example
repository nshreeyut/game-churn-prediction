# Game Churn Prediction — Environment Variables
# Copy this file to .env and fill in your API keys

# ------------------------------------------------------------------
# Game Data APIs
# ------------------------------------------------------------------

# Steam Web API key (required for Steam player + review data)
# Get one at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# RAWG.io API key (required for game metadata + reviews)
# Get one at: https://rawg.io/apidocs
GAME_CHURN_RAWG_API_KEY=

# OpenDota — no key required (public API)

# ------------------------------------------------------------------
# LLM Configuration
# ------------------------------------------------------------------
# Choose your provider: "openai" or "groq"
# Groq is free and fast — good for development and demos
# OpenAI is the default for production
LLM_PROVIDER=groq

# Groq (free) — https://console.groq.com
# Recommended models for agentic tool-calling:
#   llama-3.3-70b-versatile        (best general purpose)
#   llama3-groq-70b-8192-tool-use-preview  (optimized for tool use)
#   mixtral-8x7b-32768             (long context)
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# OpenAI — https://platform.openai.com/api-keys
# Set LLM_PROVIDER=openai and LLM_MODEL=gpt-4o-mini to use this instead
OPENAI_API_KEY=

# ------------------------------------------------------------------
# NLP / Review Summaries
# ------------------------------------------------------------------
# Used by the NLP agent to generate human-readable review summaries
# Falls back to LLM_PROVIDER above if not set separately
# SUMMARY_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------------
# Pipeline Settings
# ------------------------------------------------------------------
# How many days inactive = churned (default: 14)
# GAME_CHURN_CHURN_THRESHOLD_DAYS=14
